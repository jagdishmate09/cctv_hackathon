# Microsoft SSO (Azure AD) – required for login
MICROSOFT_CLIENT_ID=          # Application (client) ID from Azure App registration
MICROSOFT_CLIENT_SECRET=      # Client secret from Certificates & secrets
MICROSOFT_TENANT_ID=common    # Tenant ID or "common" for multi-tenant

# Must match the redirect URI configured in Azure (Authentication → Web → Redirect URIs)
REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# URL of the frontend app (where users are sent after successful sign-in)
FRONTEND_URL=http://localhost:5173

# Secret used to sign session tokens (use a strong random value in production)
SECRET_KEY=change-me-in-production

# Oracle Database (optional – for storing occupancy data)
ORACLE_URL=
ORACLE_USERNAME=
ORACLE_PASSWORD=

# Test: insert 1 row into OCCUPANCY_DATA every N seconds (60 = every 1 min, 0 = disabled)
OCCUPANCY_TEST_INSERT_INTERVAL_SEC=0
